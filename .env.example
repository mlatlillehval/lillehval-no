# ── Supabase (påkrevd for innlogging, admin, forsiden fra CMS, booking) ──
# Prosjekt: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Påkrevd i produksjon når RLS er aktivert: API-ruter (booking, ai-beredskap, frontpage)
# bruker service role. Se supabase/enable-rls.sql og kjør den i Supabase SQL Editor.
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Kommaseparert liste over e-poster som får tilgang til /admin og POST /api/frontpage-content.
# Tom i dev = alle innloggede brukere behandles som admin (se route).
# ADMIN_EMAILS=din@epost.no

# Hemmelighet for GET /api/revalidate-news?secret=… (oppfrisker nyhets-cache)
# REVALIDATE_SECRET=

# ── Stripe Checkout (nettbutikk for assistenter) ──
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# ── Booking / Calendly ──
# Full Calendly-URL (åpnes i modal når satt). Uten: brukes e-postfallback i UI.
# NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/ditt-navn/mote

# ── Nettsted-URL ──
# Produksjon (Vercel → Production): primær URL for sitemap, Stripe-retur, Open Graph og <link rel="canonical">.
# Legg også til www.lillehval.ai under Vercel → Domains (samme deploy); canonical forblir .no.
# NEXT_PUBLIC_SITE_URL=https://www.lillehval.no
#
# Lokalt (anbefalt i .env.local):
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
#
# Supabase Auth → URL Configuration: tillat redirect for begge prod-domener, f.eks.
#   https://www.lillehval.no/**  og  https://www.lillehval.ai/**  (og evt. Vercel-preview)

# ── Talkshow episode 1 ──
# YouTube-video-ID (valgfritt). Uten dette brukes public/videos/lillehval-talkshow-ep1.mp4
# NEXT_PUBLIC_TALKSHOW_EP1_YOUTUBE_ID=
